{
    "name": "raise-studio/import",
    "description": "The simplest and most complete CSV/Excel import plugin for Filament. Supports Filament 4 & 5.",
    "type": "filament-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "Raise Studio",
            "email": "494901823@qq.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/actions": "^4.0 || ^5.0",
        "filament/filament": "^4.0 || ^5.0",
        "filament/support": "^4.0 || ^5.0",
        "filament/tables": "^4.0 || ^5.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/validation": "^10.0|^11.0|^12.0|^13.0",
        "livewire/livewire": "^3.0 || ^4.0",
        "openspout/openspout": "^4.0",
        "raise-studio/license-client": "v1.0.2-beta.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "orchestra/testbench": "^8.0|^9.0",
        "mockery/mockery": "^1.5"
    },
    "autoload": {
        "psr-4": {
            "RaiseStudio\\Import\\": "src/",
            "RaiseStudio\\Import\\Pro\\": "src/Pro/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RaiseStudio\\Import\\Tests\\": "tests/",
            "RaiseStudio\\Import\\Tests\\Stubs\\": "tests/Stubs/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "RaiseStudio\\Import\\RaiseImportServiceProvider"
            ]
        },
        "filament": {
            "actions": [
                "RaiseStudio\\Import\\Actions\\ImportAction"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}